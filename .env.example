# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).

# --- Model providers ---
ANTHROPIC_API_KEY=sk-ant-placeholder
OPENAI_API_KEY=sk-placeholder
# Ollama: local OR cloud. Models churn fast, so check ollama.com/library for current tags.
#   Local model:  OLLAMA_HOST=http://localhost:11434, OLLAMA_MODEL=qwen2.5:7b (pull it first).
#   Cloud model:  run `ollama signin` (or sign in via the app) ONCE, then keep
#                 OLLAMA_HOST=http://localhost:11434 and use a :cloud tag, e.g.
#                 OLLAMA_MODEL=gpt-oss:120b-cloud. The signed-in daemon proxies + signs the
#                 request, so cloud models run on Ollama's servers with NO local GPU.
# Notes:
#   - Leave OLLAMA_API_KEY BLANK for the signed-in-daemon path above (verified working).
#   - The value at ollama.com/settings/keys is your daemon's PUBLIC KEY (ssh-ed25519 ...), which
#     you register there. It is NOT a bearer token; do not paste it into OLLAMA_API_KEY.
#   - Some :cloud models need a paid subscription (gpt-oss free; glm-5.2:cloud returns 403 until
#     you upgrade). A real bearer API token, if you have one, goes in OLLAMA_API_KEY with
#     OLLAMA_HOST=https://ollama.com.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_API_KEY=

# Default model the agent answers with (claude | openai | ollama)
DEFAULT_PROVIDER=claude
# sonnet by default: an agent loop on opus gets expensive. Swap to claude-opus-4-8 for max quality.
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5

# --- Embeddings ---
# fastembed = local, free, no key (default). openai = hosted, needs OPENAI_API_KEY.
EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Vector index (local persistent store) ---
# INDEX_PATH defaults to <repo>/data/index (gitignored). Only set it to an ABSOLUTE path if
# you want to relocate the store; a relative value would resolve against the current dir.
COLLECTION_NAME=groundwork-kb

# --- Services (internal Docker Compose hostnames) ---
# These are overrides used when a service runs INSIDE docker-compose. Leave CHROMA_HOST
# empty for local CLI runs so the on-disk PersistentClient at INDEX_PATH is used. The
# compose api service sets CHROMA_HOST=http://chroma:8000 in its own environment.
CHROMA_HOST=
RERANK_URL=http://rerank:8080
MCP_URL=http://mcp:9000
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
