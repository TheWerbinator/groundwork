# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).

# --- Model providers ---
ANTHROPIC_API_KEY=sk-ant-placeholder
OPENAI_API_KEY=sk-placeholder
# Ollama runs locally; no key. Override host if not default.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Default model the agent answers with (claude | openai | ollama)
GROUNDWORK_DEFAULT_PROVIDER=claude
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-5

# --- Embeddings ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Services (internal Docker Compose hostnames) ---
CHROMA_HOST=http://chroma:8000
RERANK_URL=http://rerank:8080
MCP_URL=http://mcp:9000
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
